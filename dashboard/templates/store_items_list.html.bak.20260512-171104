{% extends 'base.html' %}
{% load static %}
{% block content %}

<div class="container-fluid px-4 mt-3">

  <div class="row">
    <!-- Sidebar -->
    {% if on_dashboard_page %}
    <div class="col-md-2 mt-3 d-none d-lg-block">
      <h1 class="sidebar-header text-center" style="margin-top: -10px">Shop Manager</h1>
      <hr class="hr--large" />
      <a href="{% url 'dashboard:store_items_list' %}" class="sidebar-item {% if request.resolver_match.url_name == 'store_items_list' %}active{% endif %}"><i class="fas fa-box"></i>Listings</a>
      <a href="{% url 'dashboard:section_list' %}" class="sidebar-item {% if request.resolver_match.url_name == 'section_list' %}active{% endif %}"><i class="fas fa-th-large"></i>Categories</a>
      <a href="{% url 'dashboard:discount_list' %}" class="sidebar-item {% if request.resolver_match.url_name == 'discount_list' %}active{% endif %}"><i class="fas fa-percent"></i>Financials</a>
      <a href="{% url 'dashboard:order_list' %}" class="sidebar-item {% if request.resolver_match.url_name == 'order_list' %}active{% endif %}"><i class="fas fa-box"></i>Orders</a>
      <a href="{% url 'dashboard:newsletter_list' %}" class="sidebar-item {% if request.resolver_match.url_name == 'newsletter_list' %}active{% endif %}"><i class="fa fa-newspaper"></i>News Letter</a>
      <a href="{% url 'dashboard:users_list' %}" class="sidebar-item {% if request.resolver_match.url_name == 'users_list' %}active{% endif %}"><i class="fa fa-users"></i>Users</a>
    </div>
    {% endif %}

    <!-- Main Content -->
    <div class="{% if on_dashboard_page %}col-12 col-lg-10{% else %}col-12{% endif %}">

      <!-- Search Bar -->
      <div class="d-flex justify-content-end mb-4">
        <form class="d-flex w-100" action="{% url 'dashboard:dash_search' %}">
          <div class="input-group">
            <input class="form-control me-2" type="search" placeholder="Search for products" name="query" />
            <button class="btn btn-secondary" type="submit">Search</button>
          </div>
        </form>
      </div>

      <!-- ACTIONS -->
      <div class="d-flex flex-column flex-md-row align-items-start align-items-md-center mb-3">
        <a href="{% url 'dashboard:add_store_item' %}" class="btn btn-success add_btn">Add New Listing</a>

        <div class="d-flex align-items-center mb-2 mb-md-0">
          <select id="action-select" class="form-select me-2">
            <option value="">------</option>
            <option value="AC">Active</option>
            <option value="DR">Draft</option>
            <option value="IN">Inactive</option>
            <option value="SC">Showcase</option>
            <option value="SO">Sold</option>
            <option value="delete">Delete</option>
          </select>

          <button class="btn btn-primary" style="margin-left: 5px;" type="button" onclick="submitForm()">Apply</button>
        </div>
      </div>

      <!-- ITEMS WRAPPER (IMPORTANT!!) -->
      <form id="items-form" method="post" action="{% url 'dashboard:items_bulk_action' %}">
        {% csrf_token %}

        <!-- هذا الأب هو اللي رح نعمله Sortable -->
        <div class="row" id="items-sortable">

          {% for item in items %}
          <div class="col-lg-3 col-md-6 mb-4 d-flex item-card" data-id="{{ item.pk }}">
            <div class="w-100">

              <a href="{% url 'admin:TheApp_storeitems_change' item.pk %}" class="text-decoration-none">
                <div class="card-body d-flex flex-column align-items-center product-card">

                  <div class="image-container mb-2">
                    {% if item.item_photo %}
                    <img src="{{ item.item_photo.url }}" loading="lazy" class="img-fluid" />
                    {% else %}
                    <img src="{% static 'imgs/default.png' %}" loading="lazy" class="img-fluid" />
                    {% endif %}
                  </div>

                  <h5 class="card-title text-center product-title">{{ item.item_name }}</h5>
                  <p class="card-text text-center product-price">Price: ${{ item.item_price|floatformat:2 }}</p>

                  <div class="text-center">
                    {% if item.status == 'AC' %}
                    <span class="badge rounded-pill bg-success">ACTIVE</span>
                    {% elif item.status == 'DR' %}
                    <span class="badge rounded-pill bg-info">DRAFT</span>
                    {% elif item.status == 'IN' %}
                    <span class="badge rounded-pill bg-danger">INACTIVE</span>
                    {% elif item.status == 'SC' %}
                    <span class="badge rounded-pill bg-warning">SHOWCASE</span>
                    {% elif item.status == 'SO' %}
                    <span class="badge rounded-pill bg-secondary">SOLD</span>
                    {% endif %}
                  </div>

                </div>
              </a>

              <div class="text-center py-2" style="background-color: #f7f7f7;">
                <input class="form-check-input mycheck" type="checkbox" name="items" value="{{ item.pk }}" />
              </div>

            </div>
          </div>
          {% endfor %}

        </div>
      </form>

      

    </div>
  </div>
</div>

<style>
  .image-container {
    width: 90%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .image-container img {
    height: 100%;
    width: 100%;
    object-fit: cover;
  }

  .sortable-ghost {
    opacity: 0.4;
  }
</style>
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
<script>
function submitForm() {
  const form = document.getElementById('items-form');
  const actionSelect = document.getElementById('action-select');
  
  if (actionSelect.value) {
    form.action = "{% url 'dashboard:items_bulk_action' %}" + '?action=' + actionSelect.value;
    form.submit();
  } else {
    alert('Please select an action.');
  }
}
</script>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const el = document.getElementById("items-sortable");

  Sortable.create(el, {
    animation: 150,
    ghostClass: 'sortable-ghost',

    onEnd: function (evt) {
      const order = [];
      document.querySelectorAll(".item-card").forEach(card => {
        order.push(card.dataset.id);
      });

      fetch("{% url 'dashboard:update_items_order' %}", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "X-CSRFToken": "{{ csrf_token }}"
        },
        body: JSON.stringify({ order: order })
      });
    }
  });
});
</script>

{% endblock %}