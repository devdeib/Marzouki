# ----------------------------------------------------------------------------
# Marzouki / Django e-commerce — environment variables (example)
# ----------------------------------------------------------------------------
# Copy this file to `.env` on the server and fill real values.
# NEVER commit the real `.env` to git.
# ----------------------------------------------------------------------------

# --- Django ----------------------------------------------------------------
# Generate with:  python -c "import secrets;print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=replace-with-a-long-random-secret

# `False` in production.  Set to `True` only for local development.
DJANGO_DEBUG=False

# Comma-separated.  Use real domains in production.
DJANGO_ALLOWED_HOSTS=marzoukiart.com,www.marzoukiart.com

# Comma-separated full origins (scheme + host).  Used for CSRF + secure cookies.
DJANGO_CSRF_TRUSTED_ORIGINS=https://marzoukiart.com,https://www.marzoukiart.com

# --- HTTPS / Security ------------------------------------------------------
# Set to True once HTTPS is live and the reverse proxy is configured.
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
# 0 disables HSTS. Production defaults to 31536000 when unset; use 60 first if rolling out HTTPS.
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=False

# Optional: replace default CSP entirely (advanced). Leave blank for built-in policy.
DJANGO_CONTENT_SECURITY_POLICY=

# --- Database --------------------------------------------------------------
# Leave blank to use the legacy SQLite file (db.sqlite3) — useful for the very
# first deploy of the hardened build, then migrate to PostgreSQL.
#
# PostgreSQL example:
# DATABASE_URL=postgres://USER:PASSWORD@127.0.0.1:5432/marzouki
DATABASE_URL=

# --- Cache / Redis ---------------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379/1

# --- Email -----------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=Waseem Marzouki <your-email@gmail.com>

# --- Stripe ----------------------------------------------------------------
STRIPE_PUBLISHABLE_KEY=pk_live_or_pk_test_...
STRIPE_SECRET_KEY=sk_live_or_sk_test_...
# Get this from Stripe Dashboard > Developers > Webhooks > endpoint > "Signing secret".
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=usd
STRIPE_API_VERSION=2024-06-20

# --- Misc ------------------------------------------------------------------
# Optional Sentry DSN for error reporting (recommended).
SENTRY_DSN=
