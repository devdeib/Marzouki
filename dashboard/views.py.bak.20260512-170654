@staff_required
def edit_section(request, section_id):
    section = get_object_or_404(Section, id=section_id)
    items = StoreItems.objects.all().order_by("order")

    if request.method == "POST":
        form = SectionForm(request.POST, instance=section)
        if form.is_valid():
            section = form.save(commit=False)
            selected_items = form.cleaned_data["items"]
            section.items.set(selected_items)
            section.save()
            return redirect("dashboard:section_list")
    else:
        form = SectionForm(instance=section)

    section_items = set(section.items.values_list("pk", flat=True))
    checked_items = [item for item in items if item.pk in section_items]
    unchecked_items = [item for item in items if item.pk not in section_items]
    sorted_items = checked_items + unchecked_items

    return render(
        request,
        "section_detail.html",
        {
            "form": form,
            "section": section,
            "items": sorted_items,
            "category": section.category,
            "on_dashboard_page": True,
        },
    )


