@staff_required
def order_list(request):
    orders = (
        Order.objects.all()
        .select_related("user")
        .prefetch_related("items", "items__storeitem")
        .order_by("-created")
    )

    selected_year = request.GET.get("year", "")
    selected_month = request.GET.get("month", "")

    if selected_year:
        try:
            orders = orders.filter(created__year=int(selected_year))
        except ValueError:
            orders = Order.objects.none()
    if selected_month:
        try:
            orders = orders.filter(created__month=int(selected_month))
        except ValueError:
            orders = Order.objects.none()

    year_range = orders.aggregate(min_year=Min("created__year"), max_year=Max("created__year"))
    min_year = year_range["min_year"] or 2020
    max_year = year_range["max_year"] or 2025
    years = range(min_year, max_year + 1) if min_year and max_year else range(2020, 2026)

    return render(
        request,
        "order_list.html",
        {
            "orders": _paginate(request, orders, per_page=30),
            "years": years,
            "selected_year": selected_year,
            "selected_month": selected_month,
            "on_dashboard_page": True,
        },
    )


