@staff_required
@require_POST
def update_items_order(request):
    try:
        data = json.loads(request.body or "{}")
    except json.JSONDecodeError:
        return JsonResponse({"status": "error", "message": "Invalid JSON"}, status=400)

    order_list = data.get("order", [])
    if not isinstance(order_list, list):
        return JsonResponse({"status": "error"}, status=400)

    with transaction.atomic():
        for index, item_id in enumerate(order_list):
            try:
                StoreItems.objects.filter(pk=int(item_id)).update(order=index)
            except (TypeError, ValueError):
                continue
    return JsonResponse({"status": "success"})


@staff_required
@require_POST
def items_bulk_action(request):
    action = request.GET.get("action")
    selected_items = request.POST.getlist("items")
    if not selected_items:
        return redirect("dashboard:store_items_list")

    items = StoreItems.objects.filter(pk__in=selected_items)
    if action == "AC":
        items.update(status=StoreItems.ACTIVE)
    elif action == "DR":
        items.update(status=StoreItems.DRAFT)
    elif action == "IN":
        items.update(status=StoreItems.INACTIVE)
    elif action == "delete":
        items.delete()
    elif action == "SC":
        items.update(status=StoreItems.SHOWCASE)
    elif action == "SO":
        items.update(status=StoreItems.SOLD)
    return redirect("dashboard:store_items_list")


@staff_required
def dash_search(request):
    query = request.GET.get("query", "").strip()
    if query:
        results = (
            StoreItems.objects.filter(
                Q(item_name__icontains=query)
                | Q(tags__name__icontains=query)
                | Q(primary_color__name__icontains=query)
                | Q(secondary_color__name__icontains=query)
            )
            .select_related("primary_color", "secondary_color")
            .distinct()
            .order_by("order")
        )
    else:
        results = StoreItems.objects.none()

    return render(
        request,
        "dash_search_results.html",
        {"results": results, "query": query, "on_dashboard_page": True},
    )


